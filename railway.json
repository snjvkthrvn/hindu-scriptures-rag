{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c 'gunicorn --chdir /app/english-v1-rag --bind 0.0.0.0:${PORT:-5002} --workers 2 --timeout 300 --access-logfile - app:app'",
    "restartPolicyType": "ON_FAILURE"
  }
}
