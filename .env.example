# Hindu Scriptures RAG
# Copy to .env and fill in your keys.

COHERE_API_KEY=
ANTHROPIC_API_KEY=

# --- Qdrant ---
# Local Docker (docker compose):
QDRANT_URL=http://localhost:6333

# Qdrant Cloud (production): get free cluster at https://cloud.qdrant.io
# QDRANT_URL=https://your-cluster.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-cloud-api-key

# Optional: override collection name
# RAG_COLLECTION=hindu_scriptures

# Optional: set your domain for Caddy HTTPS (local Docker deployment only)
# DOMAIN=scriptures.example.com
