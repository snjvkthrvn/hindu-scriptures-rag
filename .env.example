# Hindu Scriptures RAG — copy to .env and fill in values.

# --- Required for retrieval + generation ---
COHERE_API_KEY=
ANTHROPIC_API_KEY=

# --- Qdrant ---
# Local: docker compose up -d qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=   # Qdrant Cloud only

# Optional: collection name (default hindu_scriptures or English-specific in code)
# RAG_COLLECTION=hindu_scriptures

# --- Flask ---
# Set in production so sessions persist across restarts (Linux deploys).
# FLASK_SECRET_KEY=

# --- Auth (optional) ---
# Require sign-in after guest quota (see GUEST_MESSAGE_LIMIT). Chat history for
# logged-in users is stored in data/auth.db (SQLite).
# AUTH_REQUIRED=1
# GUEST_MESSAGE_LIMIT=2
# OPEN_REGISTRATION=1
# First user when DB is empty:
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# Google OAuth (optional; pip install authlib)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# HTTPS cookies in production
# SESSION_COOKIE_SECURE=1

# --- Dev / tuning ---
# RAG_WARMUP=1
# COHERE_BATCH_DELAY_SEC=4

# Optional: Caddy local HTTPS domain (see deploy docs)
# DOMAIN=scriptures.example.com
